{
  "manifest_version": 3,
  "name": "DSA Hint Helper",
  "version": "1.0",
  "description": "Gives hints for DSA problems",

  "permissions": ["activeTab", "scripting"],

  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon":{
      "16":"icons/icon16.png",
      "48":"icons/icon48.png"
    }
  },

  "host_permissions": [
  "https://integrate.api.nvidia.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.hackerrank.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}